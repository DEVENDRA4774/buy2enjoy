PORT=10000
NODE_ENV=development

# MongoDB Atlas Free Cluster URI (M0 Sandbox)
# Example: mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/buy2enjoy?retryWrites=true&w=majority
MONGO_URI=your_mongodb_atlas_connection_string

# Authentication Secrets
JWT_SECRET=super_secret_dev_key_change_in_production
JWT_EXPIRE=30d

# Razorpay Route API Keys
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
